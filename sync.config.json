{
  "source": "RULES.md",
  "banner": "<!-- 本文件由 scripts/sync.js 从 RULES.md 自动生成，请勿直接修改。 -->\n<!-- 修改请编辑 RULES.md 后执行 `npm run sync`。 -->\n",
  "targets": [
    {
      "name": "Claude Code (项目级)",
      "scope": "project",
      "relativePath": "CLAUDE.md"
    },
    {
      "name": "Claude Code (全局)",
      "scope": "global",
      "output": "~/.claude/CLAUDE.md"
    },
    {
      "name": "Codex (项目级)",
      "scope": "project",
      "relativePath": "AGENTS.md"
    },
    {
      "name": "Codex (全局)",
      "scope": "global",
      "output": "~/.codex/AGENTS.md"
    },
    {
      "name": "Cline (项目级)",
      "scope": "project",
      "relativePath": ".clinerules/rules.md"
    },
    {
      "name": "Trae (手动粘贴，分片)",
      "scope": "manual",
      "chunkSize": 1000,
      "hint": "Trae 每次粘贴上限 1000 字符，请按分片顺序依次粘贴。"
    },
    {
      "name": "Antigravity (未知路径，复制粘贴)",
      "scope": "manual",
      "hint": "Antigravity 规则文件路径未确认，请将下方内容手动粘贴到对应位置。"
    }
  ]
}
